# ==============================================================================
# Phronesis CSO Environment Configuration Template (.env.example)
# ==============================================================================
# Copy this file to `.env` and fill in the keys or override settings as needed.
# All fields below correspond to properties in PhronesisSettings (settings.py).

# ------------------------------------------------------------------------------
# 1. LLM Backend Providers & API Keys
# ------------------------------------------------------------------------------
# Default backend selection order for `--backend auto`:
#   1. ANTHROPIC_API_KEY
#   2. NVIDIA_API_KEY (NVIDIA NIM)
#   3. OPENAI_API_KEY
#   4. GEMINI_API_KEY / GOOGLE_API_KEY
#   5. Claude Code CLI binary on PATH (no key needed)

# --- Anthropic ---
ANTHROPIC_API_KEY=
# Timeout for Anthropic API requests in seconds (default: 180.0)
# ANTHROPIC_TIMEOUT_S=180.0
# Model override (default: "claude-sonnet-4-6")
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- NVIDIA NIM ---
# Get your NIM key at: https://build.nvidia.com
# NIM model override (default: "nvidia/nemotron-3-super-120b-a12b")
NVIDIA_API_KEY=
# NIM_MODEL=nvidia/nemotron-3-super-120b-a12b

# --- OpenAI ---
OPENAI_API_KEY=
# Custom base URL (e.g. for local proxies/LLMs)
# OPENAI_BASE_URL=
# Model override (default: "gpt-4o-mini")
# OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini ---
# The runner queries Gemini models using either of the following keys
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# Model override (default: "gemini-2.5-flash")
# GEMINI_MODEL=gemini-2.5-flash

# --- Global Model Override ---
# Explicitly force a specific model string across the entire agent loop:
# VBIO_MODEL=

# ------------------------------------------------------------------------------
# 2. Logic Reasoning Engines
# ------------------------------------------------------------------------------

# --- Prometheux Hosted Vadalog Engine ---
# Active compute machine + compute management required. JarvisPy endpoint org/username
PMTX_TOKEN=
# JARVISPY_URL=https://api.prometheux.ai/jarvispy/{org}/{username}

# --- Neo4j Local Graph Database Engine (Alternative Open-Source Engine) ---
# Connection parameters for local graph reasoning via Neo4j & Cypher query patterns.
# Falls back to local in-process Python Datalog reasoning when unset/unreachable.
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=neo4j

# ------------------------------------------------------------------------------
# 3. External Integrations
# ------------------------------------------------------------------------------

# --- Tavily Search API ---
# Powers target-disease literature retrieval (lit-synthesizer skill).
# Bypassed in demo mode/--demo flag (falls back to local static mock fixtures).
TAVILY_API_KEY=

# --- PrimeKG CSV Dataset ---
# Source URL for the PrimeKG biomedical knowledge graph file.
# PRIMEKG_CSV_URL=https://raw.githubusercontent.com/mims-harvard/PrimeKG/main/primekg.csv

# ------------------------------------------------------------------------------
# 4. Observability & Tracing
# ------------------------------------------------------------------------------

# --- Langfuse Trace Mirror ---
# Both public and secret keys must be set to mirror local JSONL traces to Langfuse.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Host URL for self-hosted instances (omit to default to Langfuse Cloud)
# LANGFUSE_HOST=

# --- Structured Logging (structlog) ---
# Filter log events below this level. Options: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
# Force JSON formatting even when running on a TTY console (useful for journalctl/shippers)
# LOG_JSON=False

# ------------------------------------------------------------------------------
# 5. HTTP Server Settings (frontend/server.py)
# ------------------------------------------------------------------------------
# Steady-state request limit per IP per minute (default: 60)
# RATE_LIMIT_PER_MIN=60
# Token-bucket capacity for /api/run endpoint (default: 5)
# RATE_LIMIT_BURST=5
# Global maximum concurrent SSE in-flight runs (default: 4)
# RATE_LIMIT_CONCURRENT=4

# Allowed CORS Origin (* or list) (default: *)
# CORS_ALLOW_ORIGIN=*
# Comma-separated list of origins if CORS_ALLOW_ORIGIN=list
# CORS_ORIGIN_ALLOWLIST=
# Cache max age in seconds returned in do_OPTIONS response headers (default: 600)
# CORS_MAX_AGE_S=600

# ------------------------------------------------------------------------------
